generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  name             String
  bio              String?
  avatar           String    @default("/placeholder.svg")
  phone            String?
  faculty          String?
  career           String?
  role             String    @default("user")
  suspended        Boolean   @default(false)
  emailVerified    Boolean   @default(false)
  verifyCode       String?
  verifyCodeExpiry DateTime?
  ratingAvg        Float     @default(0)
  ratingCount      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products           Product[]
  requestsSent       MaterialRequest[] @relation("Requester")
  requestsReceived   MaterialRequest[] @relation("Owner")
  messagesSent       Message[]
  notifications      Notification[]
  historyEntries     HistoryEntry[]
  ratingsGiven       UserRating[]      @relation("Rater")
  ratingsReceived    UserRating[]      @relation("Rated")
  productRatings     ProductRating[]
  reportsFiled       Report[]          @relation("Reporter")
  reportsAgainst     Report[]          @relation("ReportedUser")
  conversationsAs1   Conversation[]    @relation("Participant1")
  conversationsAs2   Conversation[]    @relation("Participant2")
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float    @default(0)
  images      String
  category    String
  faculty     String
  career      String
  course      String
  condition   String
  transaction String
  status      String   @default("disponible")
  stock       Int      @default(1)
  location    String
  views       Int      @default(0)
  favorites   Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  requests    MaterialRequest[]
  ratings     ProductRating[]
  reports     Report[]
  history     HistoryEntry[]
  conversations Conversation[]

  @@index([category])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

model MaterialRequest {
  id          String   @id @default(cuid())
  productId   String
  requesterId String
  ownerId     String
  type        String
  status      String   @default("pendiente")
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  requester User    @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  owner     User    @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)
  history   HistoryEntry[]

  @@index([requesterId])
  @@index([ownerId])
  @@index([status])
}

model Conversation {
  id             String   @id @default(cuid())
  productId      String?
  participant1Id String
  participant2Id String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  participant1 User      @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id, productId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  filtered       Boolean  @default(false)
  filterReason   String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model HistoryEntry {
  id            String   @id @default(cuid())
  userId        String
  relatedUserId String?
  productId     String?
  requestId     String?
  type          String
  status        String
  createdAt     DateTime @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  request     MaterialRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model UserRating {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  requestId  String?
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  fromUser User @relation("Rater", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("Rated", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId])
}

model ProductRating {
  id         String   @id @default(cuid())
  fromUserId String
  productId  String
  requestId  String?
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  fromUser User    @relation(fields: [fromUserId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Report {
  id              String   @id @default(cuid())
  reporterId      String
  targetUserId    String?
  targetProductId String?
  reason          String
  status          String   @default("pendiente")
  createdAt       DateTime @default(now())

  reporter      User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser    User?    @relation("ReportedUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetProduct Product? @relation(fields: [targetProductId], references: [id], onDelete: SetNull)

  @@index([status])
}
