# Supabase — USMP Market
# Copia este archivo como .env.local y completa los valores

# URL del proyecto (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://jaoglvumppcxzyetiiiv.supabase.co

# Anon / publishable key (Dashboard → Settings → API)
# Si falla auth, usa la legacy anon key JWT del mismo panel
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Rtc3X6oGQ3eLr-LsbI_yeA_NzbA7tWQ

# Service role key — SOLO servidor, nunca exponer al cliente
# Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: reemplaza Prisma/SQLite durante la migración
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.jaoglvumppcxzyetiiiv.supabase.co:5432/postgres

# Secreto JWT legacy (eliminar cuando migres auth 100% a Supabase)
AUTH_SECRET=cambia-este-secreto-por-uno-seguro
